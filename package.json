    "lint": "oxlint",
    "format": "biome format --write src/*.ts src/*/*.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/node": "^20.11.17",
    "oxlint": "^1.55.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vite-node": "^6.0.0"
  }
}
